---
/*
  FAQ BLOCK
  ---------
  Accessible CSS accordion. No JS framework required.
  Uses <details>/<summary> for native browser support.
*/

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  eyebrow?: string;
  heading: string;
  subheading?: string;
  items?: FAQItem[];
}

const {
  eyebrow,
  heading,
  subheading,
  items = [],
} = Astro.props;
---

<section class="woc-section woc-section--surface">
  <div class="woc-container">

    <div class="woc-section-header">
      {eyebrow && <p class="woc-eyebrow">{eyebrow}</p>}
      <h2 class="woc-h2" style="margin-top: 0.5rem">{heading}</h2>
      {subheading && <p class="woc-lead" style="margin-top: 0.75rem">{subheading}</p>}
    </div>

    <div class="woc-faq" role="list">
      {items.map((item, i) => (
        <details class="woc-faq__item" role="listitem">
          <summary class="woc-faq__question">
            <span>{item.question}</span>
            <span class="woc-faq__icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </summary>
          <div class="woc-faq__answer">
            <p>{item.answer}</p>
          </div>
        </details>
      ))}
    </div>

  </div>
</section>

<style>
  .woc-section-header { margin-bottom: 2.5rem; max-width: 40rem; }

  .woc-faq { max-width: 52rem; }

  .woc-faq__item {
    border-top: 1px solid var(--color-surface-border);
    padding-block: 0.125rem;
  }
  .woc-faq__item:last-child { border-bottom: 1px solid var(--color-surface-border); }

  .woc-faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 1.25rem;
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-foreground);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .woc-faq__question::-webkit-details-marker { display: none; }

  .woc-faq__icon {
    flex-shrink: 0;
    color: var(--color-primary);
    transition: transform 0.25s ease;
  }
  details[open] .woc-faq__icon {
    transform: rotate(180deg);
  }

  .woc-faq__answer {
    padding-bottom: 1.25rem;
    padding-right: 2.5rem;
  }
  .woc-faq__answer p {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-muted);
  }
</style>
